{
  "entities": {
    "CaseHistoryEntry": {
      "title": "CaseHistoryEntry",
      "description": "A record of a completed clinical simulation case.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID of the entry." },
        "timestamp": { "type": "number", "description": "When the case was completed." },
        "diagnosis": { "type": "string", "description": "The clinical diagnosis." },
        "outcome": { "type": "string", "description": "The outcome of the case." },
        "score": { "type": "number", "description": "The score achieved (0-100)." },
        "summary": { "type": "string", "description": "A brief summary of the case." },
        "criticalEvents": { "type": "array", "items": { "type": "object" }, "description": "List of critical events." },
        "missedOpportunities": { "type": "array", "items": { "type": "string" }, "description": "List of missed opportunities." },
        "learningPoints": { "type": "array", "items": { "type": "string" }, "description": "List of learning points." },
        "userId": { "type": "string", "description": "The ID of the user who completed the case." }
      },
      "required": ["id", "timestamp", "diagnosis", "outcome", "score", "summary", "userId"]
    }
  },
  "firestore": {
    "/history/{entryId}": {
      "schema": "CaseHistoryEntry",
      "description": "User's clinical simulation history entries."
    }
  }
}
