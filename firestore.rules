rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: history
    // Document ID: auto-generated
    // Fields:
    //   - id: string (required) - entry ID
    //   - timestamp: number (required) - completion time
    //   - diagnosis: string (required) - case diagnosis
    //   - outcome: string (required) - patient outcome
    //   - score: number (required) - performance score
    //   - summary: string (required) - case summary
    //   - criticalEvents: list (optional) - list of events
    //   - missedOpportunities: list (optional) - list of missed actions
    //   - learningPoints: list (optional) - list of learning points
    //   - userId: string (required) - owner's UID
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "kltrinh@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidHistoryEntry(data) {
      return data.keys().hasAll(['timestamp', 'diagnosis', 'outcome', 'score', 'summary', 'userId']) &&
             data.timestamp is number &&
             data.diagnosis is string && data.diagnosis.size() < 500 &&
             data.outcome is string && data.outcome.size() < 500 &&
             data.score is number && data.score >= 0 && data.score <= 100 &&
             data.summary is string && data.summary.size() < 10000 &&
             data.userId is string && data.userId == request.auth.uid;
    }

    match /history/{entryId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isValidHistoryEntry(request.resource.data);
      allow update: if false; // History entries are immutable
      allow delete: if isOwner(resource.data.userId);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
  }
}
